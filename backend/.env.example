# Required: Alibaba Cloud DashScope API key
# - China region:        https://dashscope.console.aliyun.com/
# - International (SG):  https://dashscope-intl.console.aliyun.com/
DASHSCOPE_API_KEY=

# Region: "intl" (Singapore — default, recommended for MY) or "china"
# Or override fully via DASHSCOPE_BASE_URL=https://...
DASHSCOPE_REGION=intl
# DASHSCOPE_BASE_URL=

# Optional: model selection (defaults shown)
# LLM model (qwen-turbo / qwen-plus / qwen-max). qwen-turbo is fastest.
QWEN_LLM_MODEL=qwen-turbo
# STT model. Singapore region: fun-asr-realtime (recommended) — supports
# Mandarin, English, Japanese. Beijing region also supports paraformer-realtime-v2.
QWEN_STT_MODEL=fun-asr-realtime
# TTS — international (SG) supports cosyvoice-v3-flash / cosyvoice-v3-plus.
# China region also supports cosyvoice-v1 / cosyvoice-v2 / cosyvoice-v3-*.
# Voices for v3-*: longanyang, longanhuan, longhuhu_v3, longyingmu_v3
# Voices for v2:   longxiaochun_v2, longxiaobai_v2, longwan_v2, ...
QWEN_TTS_MODEL=cosyvoice-v3-flash
QWEN_TTS_VOICE=longanyang

# Optional: force the backend to use canned responses (no DashScope calls).
# Set to 1 for offline development or as a safety fallback during the demo.
MOCK_MODE=0

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=1

# CORS — comma-separated origins. Use * for hackathon demo simplicity.
CORS_ORIGINS=*
